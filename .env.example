NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLARITY_ID=
RESEND_API_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# Phase 9 — Blog Admin (server-only, local-only; never prefix with NEXT_PUBLIC_)
ADMIN_PASSWORD=
# iron-session cookie encryption secret — MUST be at least 32 characters
SESSION_SECRET=
# Google reCAPTCHA v3 (contact form spam protection). Site key is public by
# design (embedded in client JS, hence NEXT_PUBLIC_) — the secret key stays
# server-only. Leave both blank to skip verification entirely (contact form
# still works without them).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
